#!/bin/bash

################################################################################################
### sbatch configuration parameters must start with #SBATCH and must precede any other commands.
### To ignore, just add another # - like so: ##SBATCH
################################################################################################

#SBATCH --partition main			### specify partition name where to run a job. short: 7 days limit; gtx1080: 7 days; debug: 2 hours limit and 1 job at a time
#SBATCH --time   6-23:00:00    ###0-23:59:00			### limit the time of job running. Make sure it is not greater than the partition time limit!! Format: D-H:MM:SS
#SBATCH --job-name run_exp				### name of the job
#SBATCH --output /mnt/new_groups/robertmo_group/Tali/CPM_Framework_2/logs/job-%J.out			### output log for running job - %J for job number
#SBATCH --mail-user=talimal@post.bgu.ac.il	### user's email for sending job status messages
#SBATCH --mail-type=BEGIN,END,FAIL			### conditions for sending the email. ALL,BEGIN,END,FAIL, REQUEU, NONE

#SBATCH --ntasks=1
#SBATCH --mem=20G					### ammount of RAM memory
#SBATCH --cpus-per-task=1		### number of CPU cores

### sleep 8h

### Print some data to output file ###
echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"



### Start your code below ####
module load anaconda				### load anaconda module (must be present when working with conda environments)
source activate FCPM_env				### activate a conda environment, replace my_env with your conda environment
python "/mnt/new_groups/robertmo_group/Tali/CPM_Framework_2/run_experiment.py" 

