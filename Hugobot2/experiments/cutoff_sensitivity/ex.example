#!/bin/bash

################################################################################################
### sbatch configuration parameters must start with #SBATCH and must precede any other commands.
### To ignore, just add another # - like so: ##SBATCH
################################################################################################

#SBATCH --partition main			### specify partition name where to run a job. short: 7 days limit; gtx1080: 7 days; debug: 2 hours limit and 1 job at a time
#SBATCH --time   0-23:00:00    ###0-23:59:00			### limit the time of job running. Make sure it is not greater than the partition time limit!! Format: D-H:MM:SS
#SBATCH --job-name cutoff_%a				### name of the job
#SBATCH --output /home/eldarzos/execute_folder/job-%J.out			### output log for running job - %J for job number
#SBATCH --mail-user=eldarzos@post.bgu.ac.il	### user's email for sending job status messages
#SBATCH --mail-type=BEGIN,END,FAIL			### conditions for sending the email. ALL,BEGIN,END,FAIL, REQUEU, NONE

#SBATCH --ntasks=1
#SBATCH --mem=60G					### ammount of RAM memory
#SBATCH --cpus-per-task=1		### number of CPU cores

### Print some data to output file ###
echo `date`
echo -e "\nSLURM_JOBID:\t\t" $SLURM_JOBID
echo -e "SLURM_JOB_NODELIST:\t" $SLURM_JOB_NODELIST "\n\n"

### Start your code below ####
module load anaconda
source activate FCPM_env
cd /sise/robertmo-group/Eldar/projects/CPM_Framework/Hugobot2/experiments/cutoff_sensitivity

### Pass --dataset as first argument: e.g.  sbatch ex.example falls_small
python run_cutoff_sensitivity_experiment.py --dataset "$1"
